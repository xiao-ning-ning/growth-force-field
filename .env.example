# 成长力场 - 配置文件
# 复制此文件为 .env 并填入你的配置

# OpenAI 兼容接口配置
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# 服务端口
PORT=3000

# Session 密钥（必填，请使用随机字符串生成工具生成
SESSION_SECRET=CHANGE_ME_generate_a_random_secret

# 监听地址（0.0.0.0 = 局域网可访问，127.0.0.1 = 仅本机）
HOST=0.0.0.0
# 管理员默认账号（生产环境强烈建议改名）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_generate_a_random_password
# LLM API 超时（毫秒），默认 300000（5 分钟）
OPENAI_TIMEOUT=300000

# 管理员账号配置（必填）
# 建议安装后立即修改默认密码
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME
